# Montarro environment variables (set in Vercel Project Settings → Environment
# Variables). VITE_ vars are readable in the browser; both below are public.

# Generic lead webhook. The Montarro consultation form POSTs its JSON payload
# straight to this URL on submit; handle it with Make/Zapier/GHL automation.
# Payload keys: full_name, first_name, last_name, email, phone, company_name,
# goals_notes, budget_monthly_revenue, interested_service, industry, stage,
# operational_bottleneck, source.
VITE_MONTARRO_LEAD_WEBHOOK_URL=

# GoHighLevel calendar embed URL shown after the form is submitted, e.g.
# https://api.leadconnectorhq.com/widget/booking/<calendarId>
# If unset, the booking step degrades gracefully to a "we'll reach out" message.
VITE_GHL_CALENDAR_URL=
