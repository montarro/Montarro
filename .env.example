# GoHighLevel lead forwarding (server-only — set these in Vercel Project Settings
# → Environment Variables). None of these are exposed to the browser: they are
# read only inside src/lib/ghl.server.ts on the server.
#
# Choose ONE path:
#
# 1) Recommended — GHL Inbound Webhook trigger.
#    Build a workflow with an "Inbound Webhook" trigger (Montarro Consultation
#    Form / Lead Management), copy its URL here. Fields arrive as JSON by name.
GHL_WEBHOOK_URL=

# 2) Alternative — submit straight to the GHL widget form so the form's own
#    "Form submitted" workflow fires. Requires the location id for the account
#    that owns form TycKFwq8GrSYOxNlQGaE.
GHL_LOCATION_ID=
# Optional override for the GHL form-submit endpoint (defaults to the public one).
GHL_FORM_SUBMIT_URL=

# PUBLIC (VITE_ prefix → readable in the browser; this is fine, calendar embed
# URLs are public). The GoHighLevel calendar embed URL shown after the form is
# submitted, e.g. https://api.leadconnectorhq.com/widget/booking/<calendarId>
# If unset, the booking step degrades gracefully to a "we'll reach out" message.
VITE_GHL_CALENDAR_URL=
